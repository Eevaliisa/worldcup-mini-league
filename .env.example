# Copy this to .env and fill in real values. Never commit .env.

# From Supabase dashboard > Project Settings > API
PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side ONLY, used by the cron sync job.
# Never expose this with a PUBLIC_ prefix or in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# From football-data.org after registering (free tier covers the World Cup)
FOOTBALL_DATA_TOKEN=your-football-data-token-here

# A random secret string you make up — used to verify Vercel Cron is the
# one calling your sync endpoint, not a random person hitting the URL.
CRON_SECRET=make-up-a-long-random-string-here
