# Copy this to .env and fill in real values. Never commit .env.

# Supabase > Project Settings > API
PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here

# Supabase secret/service-role key — server-side ONLY (sync job + scripts).
# Never expose this with a PUBLIC_ prefix or in client code.
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-here

# football-data.org token (free tier covers the World Cup, competition code WC)
FOOTBALL_DATA_TOKEN=your-football-data-token-here

# A long random string you choose. The sync endpoint requires it as a bearer
# token so only the scheduled GitHub Action can trigger a score sync, not a
# random person hitting the URL. In production, set the SAME value as both a
# Vercel env var and a GitHub Actions secret.
CRON_SECRET=make-up-a-long-random-string-here
